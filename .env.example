GEMINI_API_KEY=
# Free tier: limites por modelo (ex. 2.5-flash pode ser ~20 geracoes/dia/projeto). Tools+visao = varias geracoes por mensagem.
GEMINI_MODEL=gemini-2.5-flash

# Provedor principal do chat: gemini | openrouter | nvidia | groq (os outros viram fallback nessa ordem)
LLM_PROVIDER=gemini
# Se false (padrao): com LLM_PROVIDER diferente de gemini, o chat NAO usa Gemini como fallback (evita cota 429).
# true = permite Gemini como fallback apos Groq/OpenRouter/NVIDIA falharem.
LLM_FALLBACK_GEMINI=false
# Visao da tela: gemini | nvidia | groq (vazio = tenta alinhar ao LLM: ex. groq se LLM_PROVIDER=groq e GROQ_API_KEY setada)
VISION_PROVIDER=gemini

# Groq (OpenAI-compatible, rapido). Chat + visao na Groq: LLM_PROVIDER=groq, VISION_PROVIDER=groq, GROQ_API_KEY.
GROQ_API_KEY=
# Modelo de texto (tools OpenAI). Ex.: llama-3.3-70b-versatile, llama-3.1-8b-instant
GROQ_MODEL=llama-3.3-70b-versatile
# Modelo multimodal para captura de tela. Ex.: meta-llama/llama-4-scout-17b-16e-instruct
GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# Fallbacks opcionais (deixe vazio se nao usar)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=qwen/qwen3-30b-a3b:free
NVIDIA_API_KEY=
NVIDIA_MODEL=meta/llama-3.1-70b-instruct
# Opcional: modelo multimodal para captura de tela (se vazio, usa NVIDIA_MODEL). Id exato em https://build.nvidia.com
NVIDIA_VISION_MODEL=

# TTS cloud opcional (normalmente pago/limitado)
OPENAI_API_KEY=
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=alloy

# Personalidade base (texto livre). Use \\n para quebras. Vazio = padrao amigavel e direto.
# Ajustes de tom que voce pedir ("prefiro que voce...", "seja mais...") vao para memoria (persona_evolution) e entram no prompt.
ASSISTANT_BASE_PERSONA=

USE_MIC=false
STT_LANGUAGE=pt-BR
STT_ENERGY_THRESHOLD=1100
STT_DYNAMIC_ENERGY=true
STT_PAUSE_THRESHOLD=0.8
STT_NON_SPEAKING_DURATION=0.35
STT_CALIBRATION_SECONDS=0.8
STT_MIN_AUDIO_SECONDS=0.35
START_VISION_TRACKER=false
START_HEARTBEAT=true
START_PROACTIVE_AGENT=false
ENABLE_CLAP_TRIGGER=true
CLAP_THRESHOLD=0.15
CLAP_MIN_GAP=0.1
CLAP_MAX_GAP=1.2
CLAP_COOLDOWN=3.0
UI_MOTION_LEVEL=balanced
UI_DENSITY=comfortable
TTS_PROVIDER=styletts2
# Ordem apos o provider principal. O padrao fica: StyleTTS2 -> Edge API -> Kokoro local.
TTS_PROVIDER_ORDER=edge,kokoro,rvc,piper,openai,elevenlabs,murf,fish,local
TTS_PREFETCH_CHUNKS=true
MURF_API_KEY=
MURF_VOICE_ID=
MURF_API_URL=https://api.murf.ai/v1/speech/generate
TTS_ALLOW_SYSTEM_PLAYER=false
# XTTS v2 (principal candidato para clonagem local)
# Instale opcionalmente: pip install coqui-tts
# Aponte para um ou mais WAV/MP3 limpos separados por ; ou ,.
XTTS_MODEL_NAME=tts_models/multilingual/multi-dataset/xtts_v2
XTTS_SPEAKER_WAV=
XTTS_LANGUAGE=pt
XTTS_DEVICE=auto
XTTS_RVC_VOICE=Jarvis
# Opcional: Python isolado com Coqui/XTTS para evitar conflito com RVC.
XTTS_PYTHON=
# Mantem o modelo carregado no worker externo; reduz muito a latencia apos o primeiro uso.
XTTS_PERSISTENT=true
# Comeca a carregar o worker em background quando o app inicia.
XTTS_PRELOAD=true
# StyleTTS2 (clone local, recomendado testar em venv isolado)
# STYLETTS2_DIFFUSION_STEPS controla qualidade vs latencia: 2-3 rapido, 5+ melhor.
STYLETTS2_PYTHON=
STYLETTS2_MODEL_CHECKPOINT=
STYLETTS2_CONFIG=
STYLETTS2_ALPHA=0.3
STYLETTS2_BETA=0.7
STYLETTS2_DIFFUSION_STEPS=3
STYLETTS2_EMBEDDING_SCALE=1.2
STYLETTS2_PERSISTENT=true
STYLETTS2_PRELOAD=false
# Alternativa: comando externo customizado. Use uma lista JSON de argumentos.
# Placeholders aceitos: {text}, {out}, {ref}
STYLETTS2_COMMAND=
STYLETTS2_REFERENCE_WAV=
# Kokoro TTS (fallback offline — roda 100% local, sem internet)
# Vozes PT-BR: pf_dora (feminina), pm_alex (masculino), pm_santa (masculino)
KOKORO_VOICE=pf_dora
KOKORO_SPEED=1.0
# Piper JARVIS (PC local): use TTS_PROVIDER=piper para testar. Edge TTS continua como fallback.
# Qualidade: medium (mais leve, recomendado para CPU antigo) ou high (mais pesado).
PIPER_REPO_ID=jgkawell/jarvis
PIPER_JARVIS_QUALITY=medium
PIPER_MODEL_FILE=
PIPER_CONFIG_FILE=
PIPER_USE_CUDA=false
PIPER_FX_PRESET=none
# Textos longos: partes de ate N caracteres por pedido Murf (cada parte = 1 geracao). Pausa em segundos entre partes.
TTS_MAX_CHUNK_CHARS=1800
TTS_PAUSE_BETWEEN_CHUNKS_SEC=0.4
REQUIRE_CRITICAL_CONFIRMATION=true
# Valor inicial da confirmação crítica (WhatsApp, apagar arquivo, etc.). O painel em Configurações > Segurança grava o estado em data/critical_confirm_enabled.json e prevalece após a primeira alteração.

# Atalho global para alternar painel / orb (biblioteca keyboard). Reinicie o app após mudar.
PANEL_HOTKEY=win+shift+a
# Se true, pedidos de visão usam instrução mais detalhada por defeito (alinha a prompts de visão).
VISION_DETAIL_DEFAULT=false
# Modo estudos/professor: injeta instruções didáticas no prompt (function calling) e incentiva uso de nexus_command / notas.
STUDY_PROFESSOR_MODE=false

GEMINI_MAX_RPM=10
GEMINI_RETRY_ATTEMPTS=3
# Timeout em segundos para chamadas HTTP (Groq/NVIDIA/OpenRouter)
LLM_HTTP_TIMEOUT=180
# true = tools nativos: Gemini (SDK) se LLM_PROVIDER=gemini; OpenAI tools se LLM_PROVIDER=nvidia ou groq. false = so marcadores [tool:...]
GEMINI_USE_FUNCTION_CALLING=true
