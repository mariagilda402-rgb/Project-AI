GEMINI_API_KEY=
# Free tier: limites por modelo (ex. 2.5-flash pode ser ~20 geracoes/dia/projeto). Tools+visao = varias geracoes por mensagem.
GEMINI_MODEL=gemini-2.5-flash

# Provedor principal do chat: gemini | openrouter | nvidia | groq (os outros viram fallback nessa ordem)
LLM_PROVIDER=gemini
# Se false (padrao): com LLM_PROVIDER diferente de gemini, o chat NAO usa Gemini como fallback (evita cota 429).
# true = permite Gemini como fallback apos Groq/OpenRouter/NVIDIA falharem.
LLM_FALLBACK_GEMINI=false
# Visao da tela: gemini | nvidia | groq (vazio = tenta alinhar ao LLM: ex. groq se LLM_PROVIDER=groq e GROQ_API_KEY setada)
VISION_PROVIDER=gemini

# Groq (OpenAI-compatible, rapido). Chat + visao na Groq: LLM_PROVIDER=groq, VISION_PROVIDER=groq, GROQ_API_KEY.
GROQ_API_KEY=
# Modelo de texto (tools OpenAI). Ex.: llama-3.3-70b-versatile, llama-3.1-8b-instant
GROQ_MODEL=llama-3.3-70b-versatile
# Modelo multimodal para captura de tela. Ex.: meta-llama/llama-4-scout-17b-16e-instruct
GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# Fallbacks opcionais (deixe vazio se nao usar)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=qwen/qwen3-30b-a3b:free
NVIDIA_API_KEY=
NVIDIA_MODEL=meta/llama-3.1-70b-instruct
# Opcional: modelo multimodal para captura de tela (se vazio, usa NVIDIA_MODEL). Id exato em https://build.nvidia.com
NVIDIA_VISION_MODEL=

# TTS cloud opcional (normalmente pago/limitado)
OPENAI_API_KEY=
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=alloy

# Personalidade base (texto livre). Use \\n para quebras. Vazio = padrao amigavel e direto.
# Ajustes de tom que voce pedir ("prefiro que voce...", "seja mais...") vao para memoria (persona_evolution) e entram no prompt.
ASSISTANT_BASE_PERSONA=

USE_MIC=false
STT_LANGUAGE=pt-BR
TTS_PROVIDER=local
MURF_API_KEY=
MURF_VOICE_ID=
MURF_API_URL=https://api.murf.ai/v1/speech/generate
TTS_ALLOW_SYSTEM_PLAYER=false
# Kokoro TTS (fallback offline — roda 100% local, sem internet)
# Vozes PT-BR: pf_dora (feminina), pm_alex (masculino), pm_santa (masculino)
KOKORO_VOICE=pf_dora
KOKORO_SPEED=1.0
# Textos longos: partes de ate N caracteres por pedido Murf (cada parte = 1 geracao). Pausa em segundos entre partes.
TTS_MAX_CHUNK_CHARS=1800
TTS_PAUSE_BETWEEN_CHUNKS_SEC=0.4
REQUIRE_CRITICAL_CONFIRMATION=true
GEMINI_MAX_RPM=10
GEMINI_RETRY_ATTEMPTS=3
# Timeout em segundos para chamadas HTTP (Groq/NVIDIA/OpenRouter)
LLM_HTTP_TIMEOUT=180
# true = tools nativos: Gemini (SDK) se LLM_PROVIDER=gemini; OpenAI tools se LLM_PROVIDER=nvidia ou groq. false = so marcadores [tool:...]
GEMINI_USE_FUNCTION_CALLING=true
