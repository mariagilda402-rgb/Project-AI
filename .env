# ==========================================
# PREDEFINICOES E CONFIGURACOES PRINCIPAIS
# ==========================================

# Provedor principal do chat: gemini | openrouter | nvidia | groq
LLM_PROVIDER=groq
# Visao da tela: gemini | nvidia | groq
VISION_PROVIDER=groq

# Janela 3D do avatar da assistente (abre no navegador)
ENABLE_VISUALIZER=true

# ==========================================
# CONFIGURACOES DE AUDIO E VOZ (TTS / STT)
# ==========================================
USE_MIC=true
STT_LANGUAGE=pt-BR

# Provedor de fala: edge | murf | openai | local
TTS_PROVIDER=edge
TTS_ALLOW_SYSTEM_PLAYER=false

# O ID de voz (ex: pt-BR-ThalitaNeural, pt-BR-AntonioNeural, alloy, etc)
OPENAI_TTS_VOICE=pt-BR-FranciscaNeural
EDGE_TTS_RATE=+0%

# Kokoro TTS (fallback offline — roda 100% local, sem internet)
# Vozes PT-BR disponiveis: pf_dora (feminina), pm_alex (masculino), pm_santa (masculino)
KOKORO_VOICE=pf_dora
KOKORO_SPEED=1.0
EDGE_TTS_VOLUME=+0%

# Otimizacao de latencia (Modo Ligacao)
TTS_MAX_CHUNK_CHARS=1800
TTS_PAUSE_BETWEEN_CHUNKS_SEC=0.1

# ==========================================
# COMPORTAMENTO E PERSONALIDADE
# ==========================================
# Personalidade base (texto livre). Use \n no .env para quebras. Vazio = padrao amigavel e direto.
ASSISTANT_BASE_PERSONA=
REQUIRE_CRITICAL_CONFIRMATION=true
GEMINI_USE_FUNCTION_CALLING=true
LLM_FALLBACK_GEMINI=false

# ==========================================
# CHAVES DE API E MODELOS ESPECIFICOS
# ==========================================

# GROQ (Recomendado para chat rapido)
#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
GROQ_API_KEY=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
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# GEMINI (Alternativa)
GEMINI_API_KEY=AIzaSyCmcKge8PL9MMG_i8S7EGSogkrUjQO1-po
GEMINI_MODEL=gemini-2.5-flash

# NVIDIA (Alternativa)
NVIDIA_API_KEY=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
NVIDIA_MODEL=nvidia/llama-3.3-nemotron-super-49b-v1.5
NVIDIA_VISION_MODEL=meta/llama-3.2-90b-vision-instruct

# OPENROUTER (Alternativa)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=qwen/qwen3-30b-a3b:free

# OPENAI (Para TTS)
OPENAI_API_KEY=
OPENAI_TTS_MODEL=gpt-4o-mini-tts

# MURF.AI (Para TTS)
