# ==========================================
# PREDEFINICOES E CONFIGURACOES PRINCIPAIS
# ==========================================

# Provedor principal do chat: gemini | openrouter | nvidia | groq | ollama
LLM_PROVIDER=gemini
# Visao da tela: gemini | nvidia | groq
VISION_PROVIDER=gemini

# Janela 3D do avatar da assistente (abre no navegador)
ENABLE_VISUALIZER=true
# Exibir console de debug no visualizador (true para depurar problemas visuais)
VISUALIZER_DEBUG=false

# ==========================================
# CONFIGURACOES DE AUDIO E VOZ (TTS / STT)
# ==========================================
USE_MIC=true
STT_LANGUAGE=pt-BR

# Provedor de fala: edge | murf | openai | local
TTS_PROVIDER=elevenlabs
TTS_ALLOW_SYSTEM_PLAYER=false

# O ID de voz do ElevenLabs (ou nome da voz Edge como fallback)
# Para ElevenLabs: Agora você pode usar apenas o NOME que você deu para a voz clonada (ex: Jarvis)
# Para Edge TTS: use o nome da voz (ex: pt-BR-FranciscaNeural, pt-BR-AntonioNeural)
OPENAI_TTS_VOICE=Jarvis
EDGE_TTS_RATE=+0%

# Kokoro TTS (fallback offline — roda 100% local, sem internet)
# Vozes PT-BR disponiveis: pf_dora (feminina), pm_alex (masculino), pm_santa (masculino)
KOKORO_VOICE=pf_dora
KOKORO_SPEED=1.0
EDGE_TTS_VOLUME=+0%


# Cole as chaves que você criar (separadas por uma vírgula):
ELEVENLABS_API_KEYS=sk_0ac9a6cc632eeb2c28c23ffb40d6daaff4db3115fcf67f0e,sk_42bdc66ff2c32d2dd6d6a8f4b65bcdfcebe9809ec50a6a4b,sk_7201c2fd4bf62b9dc37bfb0fbdc2988e1057437a0ebd70cd,sk_ff4f18b074739ce36c533dd877fa4566ce7b3aab3daabb62,sk_07b932058ed3a16bb70a8fa283bf37862f109fc8f46bc0d3,sk_b3529f1813736a187009dc9187cfbc2eb1769d1317f864ec,sk_1a0e48cafcb9796a7dc418d8426d6fb8c84489a48282c740,sk_448f8b360c13e673ba65e297f6387f266dd1e93cd39dc161,sk_da4023979e0bf9c9921ac9197680908ac565927afc4d4cd2,sk_0ff4c05bd6d448f62fe1d14543a57f3e1f585477c065968b,sk_743d546e9b913cbd8622ed0c5cd5725e558819ec46fc25c9,sk_8c7a834f6544838ad31cd2498ee1ac0b8c7d08b9da386f20,sk_89da9eada398df36d5f837c811b1501cd8293cb03bcbbc3c,aea1537597c6501d43503d5b8a9bf48842021d09643e69d090f3408b32d84d65,sk_3c9775f07446128d680ba30d322d6af6812a411c53d6b713,1615697a5851fa4b5bba9b90b402d68dbc3fe9459fe139d49b1a8adb496a0a7e,sk_9f1ab363945ac721a986ee30f2ad0251fad36ae5a574a359


# Otimizacao de latencia (Modo Ligacao)
TTS_MAX_CHUNK_CHARS=1800
TTS_PAUSE_BETWEEN_CHUNKS_SEC=0.1

# ==========================================
# COMPORTAMENTO E PERSONALIDADE
# ==========================================
# Personalidade base (texto livre). Use \n no .env para quebras. Vazio = padrao amigavel e direto.
ASSISTANT_BASE_PERSONA=
REQUIRE_CRITICAL_CONFIRMATION=true
GEMINI_USE_FUNCTION_CALLING=true
LLM_FALLBACK_GEMINI=false

# ==========================================
# CHAVES DE API E MODELOS ESPECIFICOS
